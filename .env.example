# Copy to .env and fill in. `.env` is gitignored and auto-loaded by the pipeline.
# All credentials are read-only / public-data scope.

# Read-only GitHub PAT (classic or fine-grained, public-repo read).
# Raises the API limit from 60 -> 5000 req/hr and is REQUIRED by OpenSSF Scorecard.
GITHUB_TOKEN=

# Free NVD API key: https://nvd.nist.gov/developers/request-an-api-key
# Raises the rate limit from 5 -> 50 requests / 30s. Strongly recommended.
NVD_API_KEY=

# Optional: Codeberg (Gitea) token for GNU Health metadata. Public reads work
# without it, just at a lower rate limit.
CODEBERG_TOKEN=
